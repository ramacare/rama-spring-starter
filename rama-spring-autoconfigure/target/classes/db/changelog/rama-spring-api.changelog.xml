<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="rama-spring-api-001" author="codex">
        <createTable tableName="api_header_set">
            <column name="id" type="varchar(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="headers" type="clob"/>
            <column name="created_by" type="varchar(200)"/>
            <column name="updated_by" type="varchar(200)"/>
            <column name="created_at" type="timestamp"/>
            <column name="updated_at" type="timestamp"/>
        </createTable>

        <createTable tableName="api">
            <column name="id" type="varchar(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="source_api_method" type="clob"/>
            <column name="source_api_url" type="clob"/>
            <column name="etl_code" type="clob"/>
            <column name="etl_code_error" type="clob"/>
            <column name="api_header_set_id" type="varchar(255)"/>
            <column name="created_by" type="varchar(200)"/>
            <column name="updated_by" type="varchar(200)"/>
            <column name="created_at" type="timestamp"/>
            <column name="updated_at" type="timestamp"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="api"
                                 baseColumnNames="api_header_set_id"
                                 referencedTableName="api_header_set"
                                 referencedColumnNames="id"
                                 constraintName="fk_api_header_set"/>
    </changeSet>
</databaseChangeLog>
