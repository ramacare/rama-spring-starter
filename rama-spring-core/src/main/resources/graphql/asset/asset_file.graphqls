extend type Mutation {
    addAssetFileFromBase64(base64String: String!, bucketName: String): AssetFile
}

extend type Query {
    assetFileById(id: Long!) : AssetFile
}

type AssetFile {
    id: Long
    fileName: String
    fileType: String
    md5hash: String
    originalFileName: String
    location: String
    bucketName: String
    timestampField: TimestampField
    userstampField: UserstampField
    base64String: String
}